{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Data Science Course Integration Schema",
  "description": "Schema for integrating DS track into ed-tech platform",
  "definitions": {
    "Level": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "order": { "type": "integer" },
        "title": { "type": "string" },
        "color": { "type": "string" },
        "description": { "type": "string" },
        "durationWeeks": { "type": "integer" },
        "topics": {
          "type": "array",
          "items": { "$ref": "#/definitions/Topic" }
        }
      }
    },
    "Topic": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "order": { "type": "integer" }
      }
    },
    "CodingExercise": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "topicId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "difficulty": { "enum": ["easy", "medium", "hard", "expert"] },
        "type": { "enum": ["short", "medium", "mini_assignment"] },
        "boilerplate": { "type": "object" },
        "testCases": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "input": {},
              "expectedOutput": {},
              "isHidden": { "type": "boolean" },
              "weight": { "type": "number" }
            }
          }
        },
        "hints": { "type": "array", "items": { "type": "string" } }
      }
    },
    "Mcq": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "topicId": { "type": "string" },
        "question": { "type": "string" },
        "options": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "text": { "type": "string" },
              "isCorrect": { "type": "boolean" },
              "explanation": { "type": "string" }
            }
          }
        },
        "difficulty": { "enum": ["easy", "medium", "hard", "expert"] },
        "type": { "enum": ["basic", "scenario"] }
      }
    },
    "Badge": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "requiredLevels": { "type": "array", "items": { "type": "string" } },
        "scoreThreshold": { "type": "number" }
      }
    }
  }
}
